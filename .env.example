# ── 本機開發用 .env（不要 commit 到 git）─────────────────────────────────────
# 本機透過 cloud-sql-proxy 連線時使用 localhost
# DB_URL=postgresql+asyncpg://ots_app:YOUR_PASSWORD@localhost:5433/ots

# Cloud Run / Cloud Shell 環境下使用 Unix socket
DB_URL=postgresql+asyncpg://ots_app:YOUR_PASSWORD@/ots?host=/cloudsql/ots-translation:asia-east1:ots-db-dev

PROJECT_ID=ots-translation
ENV=dev

GCS_UPLOADS_BUCKET=ots-translation-uploads-dev
GCS_OUTPUTS_BUCKET=ots-translation-outputs-dev
GCS_TEMP_BUCKET=ots-translation-pipeline-temp-dev
PUBSUB_TOPIC=ots-pipeline-trigger-dev

# ECPay sandbox（測試環境）
ECPAY_SANDBOX=true
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS

# Gemini API（試譯包 synopsis 生成）
# 1. 前往 https://aistudio.google.com/apikey 建立 API Key
# 2. 貼到下面（開發環境複製 .env.example → .env 貼上）
# 3. Cloud Run 部署時透過 Secret Manager 注入
# GEMINI_API_KEY=your_key_here

# ── Email 通知（開發環境用 SMTP / Mailpit / Mailhog）────────────────────────
# 生產環境使用 Brevo：EMAIL_PROVIDER=brevo + BREVO_API_KEY
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=noreply@ots.tw
EMAIL_FROM_NAME=OTS 翻譯服務
SMTP_HOST=localhost
SMTP_PORT=1025

# Brevo（生產環境用）
# BREVO_API_KEY=your_brevo_api_key

# ── Frontend Portal URL（email 中的連結基礎 URL）─────────────────────────────
WEB_PORTAL_URL=http://localhost:3000

# ── Notification Pub/Sub ──────────────────────────────────────────────────────
NOTIFY_TOPIC=ots-notify-dev
